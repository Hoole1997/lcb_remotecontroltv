<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LCB_Template" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/remote_primary</item>
        <item name="colorSecondary">@color/remote_primary</item>
        <item name="android:colorAccent">@color/remote_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/remote_background</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="Theme.LCB_Template" parent="Base.Theme.LCB_Template" />

    <style name="TextAppearance_LCB_HomeToolbarTitle">
        <item name="android:fontFamily">sans</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance_LCB_HomeBottomNav_Active">
        <item name="android:fontFamily">sans</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance_LCB_HomeBottomNav_Inactive">
        <item name="android:fontFamily">sans</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="HomeBottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/remote_soft_teal</item>
        <item name="android:width">56dp</item>
        <item name="android:height">30dp</item>
        <item name="marginHorizontal">10dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>

    <style name="Widget.LCB.SettingsRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minHeight">58dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.LCB.SettingsRow.Icon" parent="">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:tint">@color/remote_primary</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="Widget.LCB.SettingsRow.Title" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/remote_on_surface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.LCB.SettingsRow.Chevron" parent="">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:src">@drawable/ic_remote_chevron</item>
        <item name="android:tint">@color/remote_text_secondary</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="Widget.LCB.SettingsRow.Divider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">18dp</item>
        <item name="android:layout_marginEnd">18dp</item>
        <item name="android:background">@color/remote_outline</item>
    </style>

    <style name="Widget.LCB.RemoteButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/remote_surface</item>
        <item name="strokeColor">@color/remote_outline</item>
        <item name="android:textColor">@color/remote_on_surface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.LCB.RemoteButton.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/remote_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.LCB.SmallRemoteButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/remote_surface</item>
        <item name="strokeColor">@color/remote_outline</item>
        <item name="android:textColor">@color/remote_on_surface</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Widget.LCB.UtilityButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/remote_surface</item>
        <item name="strokeColor">@color/remote_outline</item>
        <item name="android:textColor">@color/remote_on_surface</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
