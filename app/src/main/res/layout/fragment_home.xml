<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/remote_background"
    tools:context=".HomeFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/homeToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/remote_top_bar_height"
        android:background="@color/remote_background"
        android:minHeight="@dimen/remote_top_bar_height"
        app:contentInsetEnd="18dp"
        app:contentInsetStart="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/menu_home_toolbar"
        app:title="我的电视"
        app:titleMarginStart="0dp"
        app:titleTextAppearance="@style/TextAppearance_LCB_HomeToolbarTitle"
        app:titleTextColor="@color/remote_on_surface" />

    <View
        android:id="@+id/topDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeToolbar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topDivider">

        <ImageView
            android:id="@+id/emptyIllustration"
            android:layout_width="260dp"
            android:layout_height="220dp"
            android:contentDescription="@null"
            android:src="@drawable/illustration_empty_tv"
            app:layout_constraintBottom_toTopOf="@id/emptyTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/emptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="还没有添加电视"
            android:textColor="@color/remote_on_surface"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            app:layout_constraintBottom_toTopOf="@id/emptySubtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emptyIllustration" />

        <TextView
            android:id="@+id/emptySubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="添加电视后即可快速控制客厅、卧室或公司设备"
            android:textColor="@color/remote_text_secondary"
            android:textSize="15sp"
            app:layout_constraintBottom_toTopOf="@id/emptyAddButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emptyTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/emptyAddButton"
            android:layout_width="wrap_content"
            android:layout_height="58dp"
            android:layout_marginTop="32dp"
            android:elevation="3dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:background="@drawable/bg_remote_button_primary"
            android:paddingStart="32dp"
            android:paddingEnd="36dp"
            android:text="添加电视"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_remote_add_white"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emptySubtitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dataStateContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topDivider"
        tools:visibility="visible">

        <TextView
            android:id="@+id/deviceSectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:letterSpacing="0.04"
            android:text="已添加设备"
            android:textAllCaps="false"
            android:textColor="@color/remote_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/savedTvRecycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/deviceSectionTitle"
            tools:itemCount="3"
            tools:listitem="@layout/item_saved_tv_card" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
