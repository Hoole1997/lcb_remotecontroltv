<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F7F7"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header: icon and title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- App icon -->
            <androidx.cardview.widget.CardView
                android:id="@+id/iconCv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/iv_ad_icon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_info_details" />
            </androidx.cardview.widget.CardView>

            <!-- Title and description area -->
            <LinearLayout
                android:id="@+id/contentLL"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Ad title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_ad_label"
                        android:layout_width="27dp"
                        android:layout_height="15dp"
                        android:background="@drawable/bg_ad_label_gray"
                        android:gravity="center"
                        android:text="@string/ad_label_upper"
                        android:textColor="#fff"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tv_ad_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Ad title" />
                </LinearLayout>

                <!-- Ad description -->
                <TextView
                    android:id="@+id/tv_ad_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    tools:text="Ad description" />

            </LinearLayout>

        </LinearLayout>

        <!-- CTA button -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btn_ad_cta"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_ad_cta_button"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="@string/ad_install" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
