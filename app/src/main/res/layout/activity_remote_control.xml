<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/remote_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/menu_remote_control"
        app:navigationIcon="@drawable/ic_remote_back"
        app:navigationIconTint="@color/remote_on_surface"
        app:subtitleTextAppearance="@style/TextAppearance.Material3.BodySmall"
        app:subtitleTextColor="@color/remote_text_secondary"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium"
        app:titleTextColor="@color/remote_on_surface" />

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <LinearLayout
        android:id="@+id/noIrTip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_remote_ir_tip"
        android:gravity="center_vertical"
        android:minHeight="44dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_remote_info"
            android:tint="@color/remote_warning_text" />

        <TextView
            android:id="@+id/noIrTipText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:lineSpacingExtra="1dp"
            android:text="@string/remote_no_ir_tip"
            android:textColor="@color/remote_warning_text"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noIrTip">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/powerButton"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="120dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="@string/remote_power"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/remote_orange"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_remote_power"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white" />

            <GridLayout
                android:id="@+id/dpadGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:columnCount="3"
                android:rowCount="3">

                <Space android:layout_width="58dp" android:layout_height="58dp" android:layout_margin="3dp" android:layout_row="0" android:layout_column="0" />
                <com.google.android.material.button.MaterialButton android:id="@+id/upButton" style="@style/Widget.LCB.RemoteButton" android:layout_row="0" android:layout_column="1" android:layout_gravity="center" android:layout_margin="3dp" android:text="▲" />
                <Space android:layout_width="58dp" android:layout_height="58dp" android:layout_margin="3dp" android:layout_row="0" android:layout_column="2" />
                <com.google.android.material.button.MaterialButton android:id="@+id/leftButton" style="@style/Widget.LCB.RemoteButton" android:layout_row="1" android:layout_column="0" android:layout_gravity="center" android:layout_margin="3dp" android:text="◀" />
                <com.google.android.material.button.MaterialButton android:id="@+id/okButton" style="@style/Widget.LCB.RemoteButton.Primary" android:layout_row="1" android:layout_column="1" android:layout_gravity="center" android:layout_margin="3dp" android:text="OK" />
                <com.google.android.material.button.MaterialButton android:id="@+id/rightButton" style="@style/Widget.LCB.RemoteButton" android:layout_row="1" android:layout_column="2" android:layout_gravity="center" android:layout_margin="3dp" android:text="▶" />
                <Space android:layout_width="58dp" android:layout_height="58dp" android:layout_margin="3dp" android:layout_row="2" android:layout_column="0" />
                <com.google.android.material.button.MaterialButton android:id="@+id/downButton" style="@style/Widget.LCB.RemoteButton" android:layout_row="2" android:layout_column="1" android:layout_gravity="center" android:layout_margin="3dp" android:text="▼" />
                <Space android:layout_width="58dp" android:layout_height="58dp" android:layout_margin="3dp" android:layout_row="2" android:layout_column="2" />
            </GridLayout>

            <LinearLayout
                android:id="@+id/volumeChannelRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <include
                    android:id="@+id/volumeControl"
                    layout="@layout/view_remote_vertical_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/channelControl"
                    layout="@layout/view_remote_vertical_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/utilityGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:columnCount="3">

                <com.google.android.material.button.MaterialButton android:id="@+id/muteButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_mute" />
                <com.google.android.material.button.MaterialButton android:id="@+id/sourceButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_source" />
                <com.google.android.material.button.MaterialButton android:id="@+id/homeButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_home" />
                <com.google.android.material.button.MaterialButton android:id="@+id/backRemoteButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_back" />
                <com.google.android.material.button.MaterialButton android:id="@+id/menuButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_menu" />
                <com.google.android.material.button.MaterialButton android:id="@+id/settingsButton" style="@style/Widget.LCB.UtilityButton" android:text="@string/remote_settings" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
