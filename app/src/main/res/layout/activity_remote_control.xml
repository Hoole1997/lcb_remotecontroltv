<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/remote_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_remote_back"
        app:navigationIconTint="@color/remote_on_surface"
        app:subtitleTextColor="@color/remote_text_secondary"
        app:titleTextColor="@color/remote_on_surface" />

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/powerButton"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="120dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="电源"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/remote_orange"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_remote_power"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white" />

            <GridLayout
                android:id="@+id/dpadGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:columnCount="3"
                android:rowCount="3">

                <Space android:layout_width="62dp" android:layout_height="62dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/upButton" style="@style/Widget.LCB.RemoteButton" android:layout_margin="3dp" android:text="▲" />
                <Space android:layout_width="62dp" android:layout_height="62dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/leftButton" style="@style/Widget.LCB.RemoteButton" android:layout_margin="3dp" android:text="◀" />
                <com.google.android.material.button.MaterialButton android:id="@+id/okButton" style="@style/Widget.LCB.RemoteButton.Primary" android:layout_margin="3dp" android:text="OK" />
                <com.google.android.material.button.MaterialButton android:id="@+id/rightButton" style="@style/Widget.LCB.RemoteButton" android:layout_margin="3dp" android:text="▶" />
                <Space android:layout_width="62dp" android:layout_height="62dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/downButton" style="@style/Widget.LCB.RemoteButton" android:layout_margin="3dp" android:text="▼" />
                <Space android:layout_width="62dp" android:layout_height="62dp" />
            </GridLayout>

            <LinearLayout
                android:id="@+id/volumeChannelRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <include
                    android:id="@+id/volumeControl"
                    layout="@layout/view_remote_vertical_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/channelControl"
                    layout="@layout/view_remote_vertical_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/utilityGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:columnCount="3">

                <com.google.android.material.button.MaterialButton android:id="@+id/muteButton" style="@style/Widget.LCB.UtilityButton" android:text="静音" />
                <com.google.android.material.button.MaterialButton android:id="@+id/sourceButton" style="@style/Widget.LCB.UtilityButton" android:text="信号源" />
                <com.google.android.material.button.MaterialButton android:id="@+id/homeButton" style="@style/Widget.LCB.UtilityButton" android:text="主页" />
                <com.google.android.material.button.MaterialButton android:id="@+id/backRemoteButton" style="@style/Widget.LCB.UtilityButton" android:text="返回" />
                <com.google.android.material.button.MaterialButton android:id="@+id/menuButton" style="@style/Widget.LCB.UtilityButton" android:text="菜单" />
                <com.google.android.material.button.MaterialButton android:id="@+id/settingsButton" style="@style/Widget.LCB.UtilityButton" android:text="设置" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
