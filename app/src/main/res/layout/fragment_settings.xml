<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/remote_background"
    tools:context=".SettingsFragment">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/remote_top_bar_height"
        android:gravity="center_vertical"
        android:layout_marginStart="24dp"
        android:text="设置"
        android:textColor="@color/remote_on_surface"
        android:textAppearance="@style/TextAppearance_LCB_HomeToolbarTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/topDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_tile"
                    android:backgroundTint="@color/remote_soft_teal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_remote_handset"
                        app:tint="@color/remote_primary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/appNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/remote_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/versionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@color/remote_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.04"
                android:text="通用"
                android:textColor="@color/remote_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/remote_outline" />

            <LinearLayout
                android:id="@+id/rowFeedback"
                style="@style/Widget.LCB.SettingsRow">

                <ImageView
                    style="@style/Widget.LCB.SettingsRow.Icon"
                    android:src="@drawable/ic_remote_handset" />

                <TextView
                    style="@style/Widget.LCB.SettingsRow.Title"
                    android:text="意见反馈" />

                <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
            </LinearLayout>

            <View style="@style/Widget.LCB.SettingsRow.Divider" />

            <LinearLayout
                android:id="@+id/rowRate"
                style="@style/Widget.LCB.SettingsRow">

                <ImageView
                    style="@style/Widget.LCB.SettingsRow.Icon"
                    android:src="@drawable/ic_remote_check" />

                <TextView
                    style="@style/Widget.LCB.SettingsRow.Title"
                    android:text="给个好评" />

                <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
            </LinearLayout>

            <View style="@style/Widget.LCB.SettingsRow.Divider" />

            <LinearLayout
                android:id="@+id/rowAbout"
                style="@style/Widget.LCB.SettingsRow">

                <ImageView
                    style="@style/Widget.LCB.SettingsRow.Icon"
                    android:src="@drawable/ic_remote_info" />

                <TextView
                    style="@style/Widget.LCB.SettingsRow.Title"
                    android:text="关于" />

                <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/remote_outline" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
