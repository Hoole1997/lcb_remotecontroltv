<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/remote_background"
    tools:context=".SettingsFragment">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/remote_top_bar_height"
        android:gravity="center_vertical"
        android:layout_marginStart="24dp"
        android:text="设置"
        android:textColor="@color/remote_on_surface"
        android:textAppearance="@style/TextAppearance_LCB_HomeToolbarTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/topDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/remote_surface"
                app:cardCornerRadius="@dimen/remote_corner_14"
                app:cardElevation="0dp"
                app:strokeColor="@color/remote_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_tile"
                        android:backgroundTint="@color/remote_soft_teal">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_remote_handset"
                            app:tint="@color/remote_primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/appNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="@color/remote_on_surface"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/versionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/remote_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:text="通用"
                android:textColor="@color/remote_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/remote_surface"
                app:cardCornerRadius="@dimen/remote_corner_14"
                app:cardElevation="0dp"
                app:strokeColor="@color/remote_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowFeedback"
                        style="@style/Widget.LCB.SettingsRow">

                        <ImageView
                            style="@style/Widget.LCB.SettingsRow.Icon"
                            android:src="@drawable/ic_remote_handset" />

                        <TextView
                            style="@style/Widget.LCB.SettingsRow.Title"
                            android:text="意见反馈" />

                        <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
                    </LinearLayout>

                    <View style="@style/Widget.LCB.SettingsRow.Divider" />

                    <LinearLayout
                        android:id="@+id/rowRate"
                        style="@style/Widget.LCB.SettingsRow">

                        <ImageView
                            style="@style/Widget.LCB.SettingsRow.Icon"
                            android:src="@drawable/ic_remote_check" />

                        <TextView
                            style="@style/Widget.LCB.SettingsRow.Title"
                            android:text="给个好评" />

                        <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
                    </LinearLayout>

                    <View style="@style/Widget.LCB.SettingsRow.Divider" />

                    <LinearLayout
                        android:id="@+id/rowAbout"
                        style="@style/Widget.LCB.SettingsRow">

                        <ImageView
                            style="@style/Widget.LCB.SettingsRow.Icon"
                            android:src="@drawable/ic_remote_info" />

                        <TextView
                            style="@style/Widget.LCB.SettingsRow.Title"
                            android:text="关于" />

                        <ImageView style="@style/Widget.LCB.SettingsRow.Chevron" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
