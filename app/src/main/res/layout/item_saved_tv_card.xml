<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/remote_surface"
    app:cardCornerRadius="@dimen/remote_corner_12"
    app:cardElevation="0dp"
    app:rippleColor="@color/remote_soft_teal"
    app:strokeColor="@color/remote_outline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/remote_card_min_height"
        android:paddingStart="12dp"
        android:paddingTop="11dp"
        android:paddingEnd="12dp"
        android:paddingBottom="11dp">

        <FrameLayout
            android:id="@+id/deviceIconContainer"
            android:layout_width="@dimen/remote_icon_tile"
            android:layout_height="@dimen/remote_icon_tile"
            android:background="@drawable/bg_icon_tile"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/deviceIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_remote_tv" />
        </FrameLayout>

        <TextView
            android:id="@+id/deviceNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/remote_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/metaRow"
            app:layout_constraintEnd_toStartOf="@id/chevronIcon"
            app:layout_constraintStart_toEndOf="@id/deviceIconContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="客厅电视" />

        <LinearLayout
            android:id="@+id/metaRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chevronIcon"
            app:layout_constraintStart_toEndOf="@id/deviceIconContainer"
            app:layout_constraintTop_toBottomOf="@id/deviceNameText">

            <TextView
                android:id="@+id/modelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/remote_text_secondary"
                android:textSize="12sp"
                tools:text="Xiaomi TV" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/sceneChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/remote_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="客厅" />
        </LinearLayout>

        <ImageView
            android:id="@+id/chevronIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_remote_chevron"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/remote_text_secondary" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
