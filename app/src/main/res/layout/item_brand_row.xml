<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="82dp"
    android:background="@color/remote_surface"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <FrameLayout
        android:id="@+id/iconFrame"
        android:layout_width="54dp"
        android:layout_height="42dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/tvIcon"
            android:layout_width="54dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_remote_tv" />

        <TextView
            android:id="@+id/letterText"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:gravity="center"
            android:textColor="@color/remote_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="S" />
    </FrameLayout>

    <TextView
        android:id="@+id/nameText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/remote_on_surface"
        android:textSize="21sp"
        app:layout_constraintBottom_toTopOf="@id/countText"
        app:layout_constraintEnd_toStartOf="@id/chevronIcon"
        app:layout_constraintStart_toEndOf="@id/iconFrame"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Samsung" />

    <TextView
        android:id="@+id/countText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:textColor="@color/remote_text_secondary"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/nameText"
        app:layout_constraintStart_toStartOf="@id/nameText"
        app:layout_constraintTop_toBottomOf="@id/nameText"
        tools:text="12 个型号" />

    <ImageView
        android:id="@+id/chevronIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_remote_chevron"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/remote_outline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
