<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/remote_soft_teal" />
            <stroke
                android:width="1dp"
                android:color="@color/remote_primary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/remote_background" />
            <stroke
                android:width="1dp"
                android:color="@color/remote_outline" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
